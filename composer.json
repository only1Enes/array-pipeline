{
    "name": "arraypipeline/core",
    "description": "Fluent, chainable array pipeline for PHP 8.1+ with zero dependencies.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "ArrayPipeline\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ArrayPipeline\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
